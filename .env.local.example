# Frontend
VITE_CONVEX_URL=http://127.0.0.1:3210
VITE_CONVEX_SITE_URL=http://127.0.0.1:3210
VITE_SOULHUB_SITE_URL=
VITE_SOULHUB_HOST=
VITE_SITE_MODE=
SITE_URL=http://localhost:3000
CONVEX_SITE_URL=http://127.0.0.1:3210
CONVEX_DEPLOYMENT=anonymous:anonymous-clawhub

# Convex Auth (GitHub OAuth App)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Convex Auth JWT keys (generated via @convex-dev/auth CLI)
JWT_PRIVATE_KEY=
JWKS=

# Embeddings
# Hosted dev/prod: set OPENAI_API_KEY in the Convex environment.
# Local Convex: install Ollama and run `bun run setup:local-embeddings`.
OPENAI_API_KEY=

# Optional overrides for local-development embeddings.
# EMBEDDING_PROVIDER=ollama
# OLLAMA_EMBEDDING_MODEL=qwen3-embedding:4b
# OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434
